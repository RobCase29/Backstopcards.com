# Legacy checklist-feed fallback. The app now loads the local checklist ledger first.
# Leave these blank unless you need the old feed to fill a missing checklist/multiplier gap.
PROSPECTPULSE_SUPABASE_URL=https://rhlontbdiezpefgbbkql.supabase.co
PROSPECTPULSE_ACCESS_TOKEN=
PROSPECTPULSE_EMAIL=
PROSPECTPULSE_PASSWORD=
PROSPECTPULSE_ANON_KEY=

# Private web access gate for Vercel deployments.
# Use a long random invite code and a separate random signing secret.
APP_ACCESS_CODE=
APP_SESSION_SECRET=
CRON_SECRET=

# Hosted scale layer for production deployments.
# Neon stores short-lived live-market snapshots; Upstash Redis caches repeated
# marketplace queries/rankings so the app spends fewer eBay/Fanatics requests.
DATABASE_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# If Vercel exposes the Upstash integration with KV-compatible names, those
# are accepted too:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# eBay Browse API credentials for active Buy It Now scans.
# Create keys in the eBay Developer Program, then restart the Vite dev server.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=production
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_ZIP_CODE=
EBAY_CATEGORY_ID=
EBAY_QUERY_CACHE_ENABLED=true
EBAY_BIN_QUERY_CACHE_TTL_SECONDS=86400
EBAY_AUCTION_QUERY_CACHE_TTL_SECONDS=600

# Optional: override if eBay grants Marketplace Insights with a different app scope.
EBAY_MARKETPLACE_INSIGHTS_SCOPE=
EBAY_SOLD_QUERY_CACHE_TTL_SECONDS=604800

# Fanatics Collect marketplace discovery. Uses their public search-key flow and
# live fixed-price Algolia index; do not store Fanatics account login credentials.
FANATICS_COLLECT_GRAPHQL_URL=https://app.fanaticscollect.com/graphql
FANATICS_COLLECT_ALGOLIA_APP_ID=3XT9C4X62I
FANATICS_COLLECT_ALGOLIA_INDEX=prod_item_state_v1
FANATICS_QUERY_CACHE_TTL_SECONDS=86400

# Card Hedge API credentials and local guardrails.
CARD_HEDGE_API_KEY=
CARD_HEDGE_PLAN=elite
CARD_HEDGE_RATE_LIMIT_PER_MINUTE=80
CARD_HEDGE_DAILY_LIMIT=200000
